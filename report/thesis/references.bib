@article{linBladderCancerCellsecreted2019,
  title = {Bladder Cancer Cell-Secreted Exosomal {{miR-21}} Activates the {{PI3K}}/{{AKT}} Pathway in Macrophages to Promote Cancer Progression},
  author = {Lin, Fan and Yin, Hu-Bin and Li, Xin-Yuan and Zhu, Gong-Min and He, Wei-Yang and Gou, Xin},
  date = {2019-12-03},
  journaltitle = {International Journal of Oncology},
  shortjournal = {Int J Oncol},
  volume = {56},
  number = {1},
  eprint = {31814034},
