@article{hornsteinMicroRNAMiR196Acts2005,
  title = {The {{microRNA miR-196}} Acts Upstream of {{Hoxb8}} and {{Shh}} in Limb Development},
  author = {Hornstein, Eran and Mansfield, Jennifer H. and Yekta, Soraya and Hu, Jimmy Kuang-Hsien and Harfe, Brian D. and McManus, Michael T. and Baskerville, Scott and Bartel, David P. and Tabin, Clifford J.},
  date = {2005-12},
  journaltitle = {Nature},
