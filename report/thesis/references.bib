  pmcid = {PMC4914391},
  keywords = {Animals,Carcinoma Ovarian Epithelial,Cell Line Tumor,Cell Proliferation,Cell Self Renewal,Cell Survival,Down-Regulation,Female,Gene Amplification,Gene Expression Regulation Neoplastic,Gene Knockdown Techniques,Gene Silencing,Humans,Mice Nude,MicroRNAs,Neoplasm Metastasis,Neoplasms Glandular and Epithelial,Nuclear Proteins,Ovarian Neoplasms,Promoter Regions Genetic,RNA Polymerase II,Spheroids Cellular,STAT3 Transcription Factor,Transcription Genetic,Treatment Outcome,Tumor Burden,Twist-Related Protein 1,Up-Regulation},
  file = {/home/rafail/Zotero/storage/4FQVT4CE/Chaluvally-Raghavan et al. - 2016 - Direct Upregulation of STAT3 by MicroRNA-551b-3p Deregulates Growth and Metastasis of Ovarian Cancer.pdf}
