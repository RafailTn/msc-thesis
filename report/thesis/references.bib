  title = {{{microT-CNN}}: An Avant-Garde Deep Convolutional Neural Network Unravels Functional {{miRNA}} Targets beyond Canonical Sites},
  shorttitle = {{{microT-CNN}}},
  author = {Zacharopoulou, Elissavet and Paraskevopoulou, Maria D and Tastsoglou, Spyros and Alexiou, Athanasios and Karavangeli, Anna and Pierros, Vasilis and Digenis, Stefanos and Mavromati, Galatea and Hatzigeorgiou, Artemis G and Karagkouni, Dimitra},
